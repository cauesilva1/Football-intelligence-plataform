# ============================================================
# Football Intelligence Platform — Environment Variables
# ============================================================

# Data source mode:
#   mock — in-memory generators (default, no database required — use on Vercel)
#   db   — Prisma + Postgres (requires DATABASE_URL and DIRECT_URL below)
DATA_SOURCE=mock
# DATA_SOURCE=db

# Optional: force in-memory storage locally (same as Vercel behavior)
# STORAGE_MODE=memory

# ── Postgres / Supabase (required when DATA_SOURCE=db) ─────
# Use the POOLER URL for DATABASE_URL on Vercel (port 6543 + pgbouncer).
# Use the DIRECT URL for DIRECT_URL (port 5432 — migrations / Prisma CLI only).
#
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── Supabase (optional, Sprint 4+) ────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── OpenRouter (AI scout reports) ─────────────────────────
OPENROUTER_API_KEY=

# Optional: used as HTTP-Referer header for OpenRouter analytics
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── API-Football (API-Sports) ─────────────────────────────
# Player and club enrichment — 100 req/day on free tier
APISPORTS_KEY=

# ── Vercel deploy (db mode) ─────────────────────────────────
# DATA_SOURCE=db
# DATABASE_URL=<Supabase pooler :6543 with ?pgbouncer=true>
# DIRECT_URL=<Supabase direct :5432>
#
# Vercel deploy (mock mode — no database):
# DATA_SOURCE=mock
