# ============================================================
# Football Intelligence Platform — Environment Variables
# ============================================================

# Demo mode (default) — no database required
DATA_SOURCE=mock

# Optional: force in-memory storage locally (same as Vercel behavior)
# STORAGE_MODE=memory

# ── Postgres (required for ETL load) ───────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/football_intel?schema=public
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/football_intel?schema=public

# ── Supabase (optional, Sprint 4+) ────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── AI (optional) ─────────────────────────────────────────
# ANTHROPIC_API_KEY=

# ── API-Football (API-Sports) ─────────────────────────────
# Enriquecimento lazy de times/jogadores — limite 100 req/dia no plano free
APISPORTS_KEY=

# ── Demo login ────────────────────────────────────────────
# Email: ana.ferreira@scoutclub.com
# Senha: demo1234

# ── Vercel deploy ─────────────────────────────────────────
# Set only: DATA_SOURCE=mock
# No DATABASE_URL needed
