# ============================================================
# Football Intelligence Platform — Environment Variables
# ============================================================

# Data source mode:
#   mock — in-memory generators (default, no database required — use on Vercel)
#   db   — Prisma + Postgres (requires DATABASE_URL and DIRECT_URL below)
DATA_SOURCE=mock
# DATA_SOURCE=db

# Optional: force in-memory storage locally (same as Vercel behavior)
# STORAGE_MODE=memory

# ── Postgres / Supabase (required when DATA_SOURCE=db) ─────
# DATABASE_URL: Supabase transaction pooler (port 6543) — runtime on Vercel
# DIRECT_URL: Supabase session pooler (port 5432) — migrations / Prisma CLI
#
# Required query params:
#   DATABASE_URL → pgbouncer=true, connection_limit=1, schema=public
#   DIRECT_URL   → schema=public
#
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=public"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres?schema=public"

# ── Supabase (optional, Sprint 4+) ────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── OpenRouter (AI scout reports) ─────────────────────────
OPENROUTER_API_KEY=

# Optional: used as HTTP-Referer header for OpenRouter analytics
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── API-Football (API-Sports) ─────────────────────────────
# Player and club enrichment — 100 req/day on free tier
# Player enrichment: `/players` media queries always use season=2024 (API-Sports free tier cap).
APISPORTS_KEY=

# ── Vercel deploy (db mode) ─────────────────────────────────
# DATA_SOURCE=db
# DATABASE_URL=<pooler :6543 with ?pgbouncer=true&connection_limit=1&schema=public>
# DIRECT_URL=<session pooler :5432 with ?schema=public>
#
# Vercel deploy (mock mode — no database):
# DATA_SOURCE=mock
